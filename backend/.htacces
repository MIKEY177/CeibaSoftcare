DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si el archivo existe físicamente (ej. login.php o una imagen), sírvelo directamente
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Si el archivo NO existe (rutas de React como /dashboard), mándalo al index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.html [L]
</IfModule>